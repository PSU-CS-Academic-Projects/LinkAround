# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# --- Virtual environments ---
# The bundled venv lives at LinkAround/LinkAround/ (has its own .gitignore "*"),
# but ignore the common names too in case a fresh one is created elsewhere.
venv/
.venv/
env/
ENV/

# --- Django ---
*.log
db.sqlite3
db.sqlite3-journal
# Collected static output (regenerated by `collectstatic` on deploy).
/staticfiles/
LinkAround/LinkAround_app/staticfiles/
# User-uploaded media (portfolio files) — never commit.
/media/
LinkAround/LinkAround_app/media/
# Data dump used during the SQLite -> Postgres migration.
data.json

# NOTE: the compiled Tailwind bundle
# LinkAround/LinkAround_app/LookAround/static/css/dist/styles.css IS committed
# on purpose — basic PaaS has no `npm run build` step, so the served CSS must
# be in the repo. Do not add it here.

# --- Node / Tailwind build ---
node_modules/

# --- Secrets ---
.env
.env.*
!.env.example

# --- Editor / OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
